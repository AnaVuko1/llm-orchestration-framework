# LLM Orchestration Framework - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: Custom OpenAI-compatible endpoint

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1  # Optional: Custom endpoint

# DeepSeek Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1  # Optional: Custom endpoint

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434  # Or http://ollama:11434 for Docker
OLLAMA_MODEL=llama3.2:3b  # Default model to use

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Database Configuration (if using persistent storage)
DATABASE_URL=postgresql://llm_orchestrator:changeme@localhost:5432/llm_orchestration
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Task Configuration
MAX_TASK_TIMEOUT=300  # seconds
MAX_RETRIES=3
DEFAULT_PRIORITY=3

# Agent Configuration
DEFAULT_MAX_CONCURRENCY=5
AGENT_HEALTH_CHECK_INTERVAL=60  # seconds

# Memory Configuration
CONVERSATION_BUFFER_SIZE=20
SUMMARY_THRESHOLD=10
MAX_SUMMARIES=5

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=  # Optional: Sentry DSN for error tracking